; Energy Minimization
integrator  = steep
emtol       = 1000.0
emstep      = 0.01
nsteps      = 50000

; Neighbor searching
nstlist     = 10
cutoff-scheme = Verlet
ns_type     = grid
pbc         = xyz

; Electrostatics
coulombtype = PME
rcoulomb    = 1.2

; VdW
rvdw        = 1.2
DispCorr    = EnerPres

; Output
nstxout     = 0
nstvout     = 0
nstfout     = 0
nstenergy   = 500
nstlog      = 500
